<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project>
  <PropertyGroup>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <PublishProvider>FileSystem</PublishProvider>
    <PublishUrl>D:\DesignSharpC\FmuApi\builds\x64 full</PublishUrl>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <_TargetId>Folder</_TargetId>
    <SiteUrlToLaunchAfterPublish />
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <ProjectGuid>a0a22b0e-8917-443c-893c-2b066c8c182b</ProjectGuid>
    <SelfContained>true</SelfContained>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
  
  <!-- Запуск npm build перед сборкой -->
  <Target Name="NpmBuild" BeforeTargets="Build">
    <Exec Command="npm run build" WorkingDirectory="$(ProjectDir)wwwroot" />
  </Target>
  
  <!-- Очистка папки публикации перед публикацией -->
  <Target Name="CleanPublishFolder" BeforeTargets="BeforePublish">
    <RemoveDir Directories="D:\DesignSharpC\FmuApi\builds\x64 full" />
    <MakeDir Directories="D:\DesignSharpC\FmuApi\builds\x64 full" />
    <Message Text="Publish folder cleaned: D:\DesignSharpC\FmuApi\builds\x64 full" Importance="high" />
  </Target>
  
  <!-- Копирование wwwroot в отдельную папку после публикации -->
  <Target Name="CopyWwwrootToBuilds" AfterTargets="Publish">
    <!-- Очистка целевой папки -->
    <RemoveDir Directories="D:\DesignSharpC\FmuApi\builds\wwwroot" />
    
    <!-- Создание целевой папки -->
    <MakeDir Directories="D:\DesignSharpC\FmuApi\builds\wwwroot" />
    
    <!-- Копирование папок целиком -->
    <ItemGroup>
      <CssFolderToCopy Include="$(ProjectDir)wwwroot\css\**\*.*" />
      <BundleFolderToCopy Include="$(ProjectDir)wwwroot\bundle\**\*.*" />
      <LibFolderToCopy Include="$(ProjectDir)wwwroot\lib\**\*.*" />
      <FaviconToCopy Include="$(ProjectDir)wwwroot\favicon.ico" />
    </ItemGroup>
    
    <Copy SourceFiles="@(CssFolderToCopy)" 
          DestinationFiles="@(CssFolderToCopy->'D:\DesignSharpC\FmuApi\builds\wwwroot\css\%(RecursiveDir)%(Filename)%(Extension)')" />
    
    <Copy SourceFiles="@(BundleFolderToCopy)" 
          DestinationFiles="@(BundleFolderToCopy->'D:\DesignSharpC\FmuApi\builds\wwwroot\bundle\%(RecursiveDir)%(Filename)%(Extension)')" />

    <Copy SourceFiles="@(LibFolderToCopy)" 
          DestinationFiles="@(LibFolderToCopy->'D:\DesignSharpC\FmuApi\builds\wwwroot\lib\%(RecursiveDir)%(Filename)%(Extension)')" />

    <Copy SourceFiles="@(FaviconToCopy)" 
          DestinationFiles="D:\DesignSharpC\FmuApi\builds\wwwroot\favicon.ico" />
    
    <Message Text="Wwwroot folders (css, dist, lib) copied to D:\DesignSharpC\FmuApi\builds\wwwroot" Importance="high" />
    
  </Target>
</Project>